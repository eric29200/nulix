VERSION="1.0.7"
SRC_FILENAME="stress-"$VERSION".tar.gz"
URL="https://github.com/resurrecting-open-source-projects/stress/archive/refs/tags/"$VERSION".tar.gz"

function configure_port() {
	autoreconf -i
	./configure								\
		--host=$HOST							\
		--without-gnu-malloc						\
		--prefix="/usr"							\
		ac_cv_func_malloc_0_nonnull=yes
}

function build_port() {
	make -j$NJOBS
}

function install_port() {
	make install DESTDIR=$SYSROOT
}
